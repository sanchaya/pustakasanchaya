<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : 'ಪುಸ್ತಕ ಸಂಚಯ - ಅಂತರ್ಜಾಲ ಕನ್ನಡ ಪುಸ್ತಕ ಪರಿವಿಡಿ' %></title>
  <meta name="description" content="Discover and access a vast collection of Kannada books online with Pustaka Sanchaya. Search, explore, and connect with a rich digital library.">
  <link rel="icon" type="image/x-icon" href="<%= image_path('favicon.ico') %>">
  <%= csrf_meta_tags %>
  <!-- Le HTML5 shim, for IE6-8 support of HTML elements -->
    <!--[if lt IE 9]>
      <script src="//cdnjs.cloudflare.com/ajax/libs/html5shiv/3.6.1/html5shiv.js" type="text/javascript"></script>
      <![endif]-->
      <%= stylesheet_link_tag "application", :media => "all" %>
      <%= javascript_include_tag "application" %>
      <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
      <%= analytics_init if Rails.env.production? %>
    </head>
    <body>

      <div class="navbar navbar-default navbar-static-top">
        <div class="container">
          <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-responsive-collapse">
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
          </button>
          <a href="<%= root_path %> " class="navbar-brand">
            <%= image_tag('pustaka-logo.png', class: 'header-logo-img', alt: 'ಪುಸ್ತಕ ಸಂಚಯ') %>
            <span class="header-logo-text"><%= t(:pustaka_sanchaya) %></span>
          </a>
          <div class="navbar-collapse collapse navbar-responsive-collapse">
            <ul class="nav navbar-nav">
              <li> <%= link_to t(:category), categories_path %> </li>
              <li> <%= link_to 'ವಿಕಿ', '/wiki' %> </li>
              <li> <%= link_to 'ಮೂಲ', stores_path %> </li>
              <li> <%= link_to t(:about_us), '/about' %> </li>
              <li> <%= link_to t(:help), '/help' %> </li>
              <li> <%= link_to t(:contact), '/help' %> </li>
            </ul>
            <%= render 'layouts/nav_social' %>
          </div>
        </div>
      </div>

      <div class="container main-content">
        <div class="row">
          <%= bootstrap_flash %>
          <%= yield %>
        </div>
      </div>

      <footer class="footer">
        <div class="container">
          <div class="copy-right">
            &copy; Since 2010 <a href="https://sanchaya.org" target="_blank"> ಕನ್ನಡ ಸಂಚಯ </a>| ಸಾಹಿತ್ಯ ಸಂಶೋಧನೆ ಹಾಗೂ ಅಧ್ಯಯನ ವೇದಿಕೆ
          </div>
        </div>
      </footer>
    </body>
</html>
