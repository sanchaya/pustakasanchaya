<!DOCTYPE html>
<html lang="en" data-cfasync="false">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1">
  <link href="https://fonts.googleapis.com/css?family=Noto+Sans+Kannada" rel="stylesheet">
  <title><%= content_for?(:title) ? yield(:title) : 'ಪುಸ್ತಕ ಸಂಚಯ - Kannada Books Index | ಕನ್ನಡ ಪುಸ್ತಕಗಳ ಪರಿವಿಡಿ' %></title>
  <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'ಪುಸ್ತಕ ಸಂಚಯ - Kannada Books Index. ಕನ್ನಡ ಪುಸ್ತಕಗಳ ಅಂತರ್ಜಾಲ ಸಂಗ್ರಹ. ಸಾವಿರಾರು ಕನ್ನಡ ಪುಸ್ತಕಗಳನ್ನು ಹುಡುಕಿ, ಅನ್ವೇಷಿಸಿ ಮತ್ತು ಓದಿ. Kannada Digital Books, Kannada Books Online, ಕನ್ನಡ ಡಿಜಿಟಲ್ ಪುಸ್ತಕಗಳು.' %>">
  <meta name="keywords" content="<%= content_for?(:meta_keywords) ? yield(:meta_keywords) : 'Kannada Books Index, Kannada Digital Books, Kannada Books Online, Kannada Books, ಕನ್ನಡ ಪುಸ್ತಕಗಳು, ಕನ್ನಡ ಡಿಜಿಟಲ್ ಪುಸ್ತಕಗಳು, ಕನ್ನಡ ಪುಸ್ತಕಗಳ ಪರಿವಿಡಿ, Kannada Literature, Kannada Ebooks, ಕನ್ನಡ ಸಾಹಿತ್ಯ, Kannada Book Search, ಕನ್ನಡ ಪುಸ್ತಕ ಹುಡುಕು, Online Kannada Library, ಕನ್ನಡ ಗ್ರಂಥಾಲಯ' %>">
  <% if content_for?(:noindex) %><meta name="robots" content="noindex"><% end %>
  <link rel="canonical" href="<%= request.original_url %>">
  <link rel="icon" type="image/x-icon" href="<%= image_path('favicon.ico') %>">
  <%= csrf_meta_tags %>
  <!-- Le HTML5 shim, for IE6-8 support of HTML elements -->
    <!--[if lt IE 9]>
      <script src="//cdnjs.cloudflare.com/ajax/libs/html5shiv/3.6.1/html5shiv.js" type="text/javascript"></script>
      <![endif]-->
      <%= stylesheet_link_tag "application", :media => "all" %>
      <style>
  body {
    font-family: 'Noto Sans Kannada', sans-serif;
    background-color: #f4f7f6;
  }
  .navbar-brand {
    font-weight: bold;
    color: #5F3792 !important;
  }
  .navbar-default .navbar-nav > li > a {
    color: #333;
    font-weight: 500;
  }
  .footer {
    background-color: #5F3792;
    color: white;
    padding: 20px 0;
    margin-top: 30px;
  }
  .footer .copy-right a {
    color: #fff;
  }
</style>
      <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
      <%= analytics_init if Rails.env.production? %>
    </head>
    <body>

      <div class="navbar navbar-default navbar-static-top">
        <div class="container">
          <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-responsive-collapse">
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
          </button>
          <a href="<%= root_path %> " class="navbar-brand">
            <%= image_tag('sanchaya-logo.png', class: 'header-logo-img', alt: 'ಪುಸ್ತಕ ಸಂಚය') %>
            <span class="header-logo-text"><%= t(:pustaka_sanchaya) %></span>
          </a>
          <div class="navbar-collapse collapse navbar-responsive-collapse">
            <ul class="nav navbar-nav">
              <li> <%= link_to t(:category), categories_path %> </li>
              <li> <%= link_to 'ಲೇಖಕರು', authors_path %> </li>
              <li> <%= link_to 'ಪ್ರಕಾಶಕರು', publishers_path %> </li>
              <li> <%= link_to 'ವಿಕಿ', '/wiki' %> </li>
              <li> <%= link_to 'ಮೂಲ', stores_path %> </li>
              <li> <%= link_to t(:about_us), '/about' %> </li>
              <li> <%= link_to t(:help), '/help' %> </li>
            </ul>
            <%= render 'layouts/nav_social' %>
          </div>
        </div>
      </div>

      <div class="container main-content">
        <div class="row">
          <%= bootstrap_flash %>
          <%= yield %>
        </div>
      </div>

      <footer class="footer">
        <div class="container">
          <div class="copy-right">
            &copy; Since 2010 <a href="https://sanchaya.org" target="_blank"> ಕನ್ನಡ ಸಂಚಯ </a>| ಸಾಹಿತ್ಯ ಸಂಶೋಧನೆ ಹಾಗೂ ಅಧ್ಯಯನ ವೇದಿಕೆ
          </div>
        </div>
      </footer>
    </body>
</html>
