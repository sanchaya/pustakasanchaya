<% content_for :title, "Authors - ಪುಸ್ತಕ ಸಂಚಯ" %>

<div style="background: linear-gradient(135deg, #5F3792, #7e57c2); color: #fff; padding: 20px; border-radius: 8px; margin-bottom: 20px; text-align: center;">
  <h2 style="margin: 0 0 6px 0; font-size: 22px;">ಲೇಖಕರು</h2>
  <p style="margin: 0; opacity: 0.9; font-size: 14px;">ಕನ್ನಡ ಪುಸ್ತಕಗಳ ಲೇಖಕರ ಪಟ್ಟಿ. ಅಕ್ಷರ ಆಯ್ಕೆ ಮಾಡಿ ಅಥವಾ ಹುಡುಕಾಟ ನಡೆಸಿ.</p>
</div>

<div class="row">
  <div class="col-md-12">
    <div class="card">
      <div class="card-body">
        <div style="margin-bottom: 15px;">
          <input type="text" id="search-input" class="form-control" placeholder="ಹುಡುಕು ಲೇಖಕರು..." style="font-family: 'Noto Sans Kannada', sans-serif;">
        </div>

        <%= render 'application/letter_bar' %>

        <div style="margin-bottom: 15px;">
          <h4 style="margin: 0 0 12px 0; color: #5F3792; font-size: 16px;">ಪ್ರಮುಖ ಲೇಖಕರು</h4>
          <div style="display: flex; flex-wrap: wrap; gap: 8px;" id="popular-authors"></div>
        </div>

        <div id="results" style="min-height: 100px;">
          <p class="text-muted text-center" style="padding: 30px 0; margin: 0;">ಮೇಲಿನ ಅಕ್ಷರ ಆಯ್ಕೆ ಮಾಡಿ ಅಥವಾ ಹುಡುಕಿರಿ</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var searchInput = document.getElementById('search-input');
  var resultsDiv = document.getElementById('results');
  var popularDiv = document.getElementById('popular-authors');
  var letterBtns = document.querySelectorAll('.letter-btn');
  var searchTimer;
  var allData = [];
  var filteredData = [];
  var displayCount = 0;
  var pageSize = 20;

  function clearLetterActive() {
    letterBtns.forEach(function(b) {
      b.style.background = '#f8f8f8';
      b.style.color = '#333';
    });
  }

  function setActive(btn) {
    if (btn) {
      btn.style.background = '#5F3792';
      btn.style.color = '#fff';
    }
  }

  function renderList() {
    var data = filteredData;
    if (!data || data.length === 0) {
      resultsDiv.innerHTML = '<p class="text-muted text-center" style="padding: 30px 0; margin: 0;">ಯಾವುದೇ ಫಲಿತಾಂಶಗಳಿಲ್ಲ</p>';
      return;
    }
    var itemsToShow = data.slice(0, displayCount);
    var html = '';
    itemsToShow.forEach(function(item) {
      html += '<a href="/authors/' + item.slug + '" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 15px; border-bottom: 1px solid #f0f0f0; text-decoration: none; color: #333; transition: background 0.15s;">';
      html += '<span style="font-size: 14px;">' + item.name + '</span>';
      html += '<span style="font-size: 12px; color: #999; white-space: nowrap; margin-left: 10px;">';
      if (item.books) html += '<span title="Books"><i class="fa fa-book" style="margin-right:3px;color:#5F3792;"></i>' + item.books + '</span> ';
      if (item.publishers) html += '<span title="Publishers"><i class="fa fa-building" style="margin-right:3px;color:#933586;"></i>' + item.publishers + '</span>';
      html += '</span></a>';
    });
    html = '<div style="border: 1px solid #e0e0e0; border-radius: 6px; overflow: hidden;">' + html + '</div>';
    if (displayCount < data.length) {
      html += '<div style="text-align: center; margin-top: 15px;"><button id="show-more-btn" class="btn btn-sm btn-outline-primary" style="padding: 8px 30px;">ಹೆಚ್ಚು ತೋರಿಸು (' + (data.length - displayCount) + ' ಉಳಿದಿವೆ)</button></div>';
    } else {
      html += '<p class="text-muted text-center" style="padding: 10px 0; margin: 0; font-size: 12px;">ಒಟ್ಟು ' + data.length + ' ಫಲಿತಾಂಶಗಳು</p>';
    }
    resultsDiv.innerHTML = html;
    var showMoreBtn = document.getElementById('show-more-btn');
    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', function() {
        displayCount += pageSize;
        renderList();
      });
    }
  }

  function loadResults(letter, query) {
    filteredData = allData;
    if (letter) {
      filteredData = filteredData.filter(function(item) { return item.name.indexOf(letter) === 0; });
    }
    if (query) {
      var q = query.toLowerCase();
      filteredData = filteredData.filter(function(item) { return item.name.toLowerCase().indexOf(q) !== -1; });
    }
    displayCount = pageSize;
    renderList();
  }

  fetch(window.location.pathname + '?format=json')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      allData = data || [];
      var popular = allData.slice(0, 12);
      var pHtml = '';
      popular.forEach(function(item) {
        pHtml += '<a href="/authors/' + item.slug + '" style="display: inline-block; padding: 8px 16px; background: #f0edf5; border-radius: 20px; text-decoration: none; color: #5F3792; font-size: 13px; border: 1px solid #e0d8ed;">';
        pHtml += item.name;
        pHtml += '</a>';
      });
      popularDiv.innerHTML = pHtml;
    });

  searchInput.addEventListener('keyup', function() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(function() {
      clearLetterActive();
      loadResults('', searchInput.value.trim());
    }, 300);
  });

  letterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      clearLetterActive();
      setActive(btn);
      searchInput.value = '';
      loadResults(btn.getAttribute('data-letter'), '');
    });
  });
});
</script>
