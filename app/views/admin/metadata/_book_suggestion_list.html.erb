<div class="row">
  <% suggestions.each do |s| %>
    <div class="col-md-6 mb-3">
      <div class="card suggestion-card" id="suggestion-<%= s[:id] %>">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <span class="badge bg-info badge-confidence">Exact match</span>
            <small class="text-muted">100% confidence</small>
          </div>

          <div class="row align-items-center">
            <div class="col-5 text-end">
              <div style="font-size: 0.85rem;">
                <strong><%= truncate(s[:source_title], length: 40) %></strong>
              </div>
              <small class="text-muted"><%= s[:source_author] %></small>
              <br>
              <span class="badge bg-secondary mt-1"><%= s[:source_library] %></span>
            </div>
            <div class="col-2 text-center merge-arrow">
              <i class="fas fa-arrow-right"></i>
            </div>
            <div class="col-5">
              <div style="font-size: 0.85rem;">
                <strong><%= truncate(s[:target_title], length: 40) %></strong>
              </div>
              <small class="text-muted"><%= s[:target_author] %></small>
              <br>
              <span class="badge bg-secondary mt-1"><%= s[:target_library] %></span>
            </div>
          </div>

          <div class="mt-3 text-center">
            <button class="btn btn-sm btn-success me-2" onclick="applySuggestion('book', '<%= s[:source] %>', '<%= s[:target] %>', this)">
              <i class="fas fa-code-merge"></i> Merge
            </button>
            <button class="btn btn-sm btn-outline-secondary" onclick="dismissSuggestion('book', '<%= s[:source] %>', '<%= s[:target] %>', this)">
              <i class="fas fa-times"></i> Dismiss
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
