<div class="container-fluid mt-4">
  <div class="row mb-4">
    <div class="col-md-8">
      <h1>Manage Libraries</h1>
      <p class="text-muted">Edit and merge library names across all books</p>
    </div>
    <div class="col-md-4 text-end">
      <span class="badge bg-primary fs-6"><%= @libraries.total_count %> unique libraries</span>
    </div>
  </div>

  <!-- Search Box -->
  <div class="card mb-4">
    <div class="card-body">
      <form method="get" class="row g-2">
        <div class="col-md-8">
          <input type="text" name="search" class="form-control" placeholder="Search libraries..." value="<%= @search_query %>">
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Libraries Table -->
  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Library Name</th>
            <th class="text-end">Books</th>
            <th class="text-end" style="width: 200px;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @libraries.each do |library| %>
            <tr>
              <td>
                <strong><%= library[:name] %></strong>
              </td>
              <td class="text-end">
                <span class="badge bg-light text-dark"><%= library[:count] %></span>
              </td>
              <td class="text-end">
                <button class="btn btn-sm btn-outline-primary" onclick="openRenameModal('<%= library[:name].gsub("'", "\\'") %>')">
                  Rename
                </button>
                <button class="btn btn-sm btn-outline-success" onclick="openMergeModal('<%= library[:name].gsub("'", "\\'") %>')">
                  Merge
                </button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <div class="mt-4">
    <%= paginate @libraries %>
  </div>
</div>

<!-- Rename Modal -->
<div class="modal fade" id="renameModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Rename Library</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Current Name</label>
          <input type="text" id="renameOldName" class="form-control" readonly>
        </div>
        <div class="mb-3">
          <label class="form-label">New Name</label>
          <input type="text" id="renameNewName" class="form-control" placeholder="Enter new library name">
        </div>
        <div id="renameError" class="alert alert-danger d-none" role="alert"></div>
        <div id="renameSuccess" class="alert alert-success d-none" role="alert"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="submitRename()">Rename</button>
      </div>
    </div>
  </div>
</div>

<!-- Merge Modal -->
<div class="modal fade" id="mergeModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Merge Library</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">From (will be replaced)</label>
          <input type="text" id="mergeOldLibrary" class="form-control" readonly>
        </div>
        <div class="mb-3">
          <label class="form-label">Type library name to merge with</label>
          <input type="text" id="mergeNewLibrary" class="form-control" placeholder="Enter library name to merge with" oninput="findSimilarLibraries()">
          <small class="text-muted">Start typing to find similar names</small>
        </div>
        <div id="mergeSimilarList" class="mb-3">
          <!-- Similar libraries will appear here -->
        </div>
        <div id="mergeError" class="alert alert-danger d-none" role="alert"></div>
        <div id="mergeSuccess" class="alert alert-success d-none" role="alert"></div>
        <div id="mergePreview" class="d-none">
          <div class="alert alert-info">
            This will update <strong id="mergeAffectedCount">0</strong> books
          </div>
          <div id="mergePreviewBooks" style="max-height: 300px; overflow-y: auto;"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" onclick="submitMerge()">Merge Libraries</button>
      </div>
    </div>
  </div>
</div>

<script>
let renameModal, mergeModal;

document.addEventListener('DOMContentLoaded', function() {
  renameModal = new bootstrap.Modal(document.getElementById('renameModal'));
  mergeModal = new bootstrap.Modal(document.getElementById('mergeModal'));
});

function openRenameModal(libraryName) {
  document.getElementById('renameOldName').value = libraryName;
  document.getElementById('renameNewName').value = '';
  document.getElementById('renameError').classList.add('d-none');
  document.getElementById('renameSuccess').classList.add('d-none');
  renameModal.show();
}

function openMergeModal(libraryName) {
  document.getElementById('mergeOldLibrary').value = libraryName;
  document.getElementById('mergeNewLibrary').value = '';
  document.getElementById('mergeSimilarList').innerHTML = '';
  document.getElementById('mergeError').classList.add('d-none');
  document.getElementById('mergeSuccess').classList.add('d-none');
  document.getElementById('mergePreview').classList.add('d-none');
  mergeModal.show();
}

function submitRename() {
  const oldName = document.getElementById('renameOldName').value;
  const newName = document.getElementById('renameNewName').value;
  
  if (!newName || newName.trim() === '') {
    showRenameError('Please enter a new library name');
    return;
  }
  
  fetch('<%= admin_rename_library_path %>', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': '<%= form_authenticity_token %>'
    },
    body: JSON.stringify({
      old_name: oldName,
      new_name: newName
    })
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      showRenameSuccess(`Successfully renamed library! Updated ${data.affected_count} books`);
      setTimeout(() => location.reload(), 2000);
    } else {
      showRenameError(data.error || 'Failed to rename library');
    }
  })
  .catch(error => {
    showRenameError('An error occurred: ' + error.message);
  });
}

function findSimilarLibraries() {
  const libraryName = document.getElementById('mergeNewLibrary').value;
  
  if (!libraryName || libraryName.trim().length < 2) {
    document.getElementById('mergeSimilarList').innerHTML = '';
    return;
  }
  
  const url = new URL('<%= admin_find_similar_libraries_path %>', window.location.origin);
  url.searchParams.append('library', libraryName);
  
  fetch(url.toString(), {
    method: 'GET',
    headers: {
      'X-CSRF-Token': '<%= form_authenticity_token %>'
    }
  })
  .then(response => response.json())
  .then(data => {
    displaySimilarLibraries(data.similar);
  })
  .catch(error => console.error('Error:', error));
}

function displaySimilarLibraries(similar) {
  const list = document.getElementById('mergeSimilarList');
  
  if (similar.length === 0) {
    list.innerHTML = '<small class="text-muted">No similar libraries found</small>';
    return;
  }
  
  let html = '<div class="list-group">';
  similar.forEach(library => {
    html += `<button type="button" class="list-group-item list-group-item-action" onclick="selectMergeLibrary('${library.replace(/'/g, "\\'")}')">${library}</button>`;
  });
  html += '</div>';
  
  list.innerHTML = html;
}

function selectMergeLibrary(libraryName) {
  document.getElementById('mergeNewLibrary').value = libraryName;
  document.getElementById('mergeSimilarList').innerHTML = '';
}

function submitMerge() {
  const oldLibrary = document.getElementById('mergeOldLibrary').value;
  const newLibrary = document.getElementById('mergeNewLibrary').value;
  
  if (!newLibrary || newLibrary.trim() === '') {
    showMergeError('Please select a library to merge with');
    return;
  }
  
  if (oldLibrary === newLibrary) {
    showMergeError('Source and target libraries must be different');
    return;
  }
  
  fetch('<%= admin_merge_libraries_path %>', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': '<%= form_authenticity_token %>'
    },
    body: JSON.stringify({
      old_library: oldLibrary,
      new_library: newLibrary
    })
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      showMergeSuccess(`Successfully merged! Updated ${data.affected_count} books`);
      setTimeout(() => location.reload(), 2000);
    } else {
      showMergeError(data.error || 'Failed to merge libraries');
    }
  })
  .catch(error => {
    showMergeError('An error occurred: ' + error.message);
  });
}

function showRenameError(msg) {
  const el = document.getElementById('renameError');
  el.textContent = msg;
  el.classList.remove('d-none');
}

function showRenameSuccess(msg) {
  const el = document.getElementById('renameSuccess');
  el.textContent = msg;
  el.classList.remove('d-none');
}

function showMergeError(msg) {
  const el = document.getElementById('mergeError');
  el.textContent = msg;
  el.classList.remove('d-none');
}

function showMergeSuccess(msg) {
  const el = document.getElementById('mergeSuccess');
  el.textContent = msg;
  el.classList.remove('d-none');
}
</script>
