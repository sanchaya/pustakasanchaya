<div class="container-fluid mt-4">
  <div class="row mb-4">
    <div class="col-md-8">
      <h1>Manage Stores & Portals</h1>
      <p class="text-muted">Manage online book stores and library portals</p>
    </div>
    <div class="col-md-4 text-end">
      <span class="badge bg-primary fs-6"><%= @total_stores %> stores</span>
      <span class="badge bg-success fs-6"><%= @active_stores %> active</span>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-12 text-end">
      <a href="<%= admin_new_store_path %>" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add Store
      </a>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th style="width: 60px;">Logo</th>
            <th>Store Name</th>
            <th>URL</th>
            <th class="text-center">Books</th>
            <th class="text-center">Position</th>
            <th class="text-center">Status</th>
            <th class="text-center" style="width: 200px;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @stores.each do |store| %>
            <tr>
              <td>
                <% if store.logo.present? %>
                  <img src="<%= store.logo %>" alt="<%= store.name %>" style="width: 40px; height: 40px; object-fit: contain;">
                <% else %>
                  <div class="d-flex align-items-center justify-content-center bg-light" style="width: 40px; height: 40px;">
                    <i class="fas fa-store text-muted"></i>
                  </div>
                <% end %>
              </td>
              <td>
                <strong><%= store.name %></strong>
              </td>
              <td>
                <% if store.url.present? %>
                  <a href="<%= store.url %>" target="_blank" class="text-decoration-none">
                    <%= truncate(store.url, length: 40) %>
                  </a>
                <% else %>
                  <span class="text-muted">-</span>
                <% end %>
              </td>
              <td class="text-center">
                <span class="badge bg-light text-dark"><%= store.books.count %></span>
              </td>
              <td class="text-center">
                <%= store.position %>
              </td>
              <td class="text-center">
                <% if store.active? %>
                  <span class="badge bg-success">Active</span>
                <% else %>
                  <span class="badge bg-secondary">Inactive</span>
                <% end %>
              </td>
              <td class="text-center">
                <a href="<%= admin_edit_store_path(store) %>" class="btn btn-sm btn-outline-primary">
                  <i class="fas fa-edit"></i> Edit
                </a>
                <%= button_to admin_toggle_store_path(store), method: :post, class: "btn btn-sm btn-outline-warning", style: "display: inline-block;", form: { style: "display: inline-block;" } do %>
                  <% if store.active? %>
                    <i class="fas fa-eye-slash"></i> Deactivate
                  <% else %>
                    <i class="fas fa-eye"></i> Activate
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>