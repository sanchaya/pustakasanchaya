<% content_for :page_title do %>
  Manage Duplicates
<% end %>

<div class="row mb-4">
  <div class="col-md-12">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title" style="color: #5F3792;">
          <i class="fas fa-clone"></i> Find Duplicate Records
        </h5>
        <p class="text-muted">The system will automatically detect and suggest potential duplicates.</p>

        <div class="row">
          <div class="col-md-4">
            <button class="btn btn-primary w-100 mb-3" onclick="findDuplicates('author')">
              <i class="fas fa-user"></i> Find Duplicate Authors
            </button>
          </div>
          <div class="col-md-4">
            <button class="btn btn-primary w-100 mb-3" onclick="findDuplicates('publisher')">
              <i class="fas fa-building"></i> Find Duplicate Publishers
            </button>
          </div>
          <div class="col-md-4">
            <button class="btn btn-primary w-100 mb-3" onclick="findDuplicates('name')">
              <i class="fas fa-book"></i> Find Duplicate Titles
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="resultsContainer"></div>

<script>
  function findDuplicates(field) {
    const container = document.getElementById('resultsContainer');
    container.innerHTML = '<div class="text-center"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';

    fetch('<%= admin_find_duplicates_path %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({ field: field })
    })
    .then(response => response.json())
    .then(data => {
      if (!data.duplicates || data.duplicates.length === 0) {
        container.innerHTML = '<div class="alert alert-info"><i class="fas fa-info-circle"></i> No duplicate ' + field + 's found.</div>';
        return;
      }

      let html = `<div class="card"><div class="card-body">
        <h5 class="card-title" style="color: #5F3792;">
          <i class="fas fa-list"></i> Potential Duplicate ${field.charAt(0).toUpperCase() + field.slice(1)}s 
          <span class="badge bg-danger">${data.count}</span>
        </h5>`;

      data.duplicates.forEach((group, index) => {
        html += `<div class="card mb-3" style="border-left: 4px solid #5F3792;">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div>
                <h6 class="mb-1">${group.value}</h6>
                <small class="text-muted">${group.count} books with this ${field}</small>
              </div>
              <button class="btn btn-sm btn-outline-primary" onclick="selectGroup(${index})">
                <i class="fas fa-check-circle"></i> Merge These
              </button>
            </div>
            <div class="table-responsive">
              <table class="table table-sm mb-0">
                <thead style="background: #f5f5f5;">
                  <tr>
                    <th style="width: 40px;"><input type="checkbox" class="form-check-input" onchange="toggleBook(this, ${index})"></th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Publisher</th>
                    <th>Source</th>
                  </tr>
                </thead>
                <tbody>`;

        group.books.forEach(book => {
          html += `<tr>
            <td><input type="checkbox" class="form-check-input book-selector" data-group="${index}" data-id="${book.source_identifier}"></td>
            <td><small>${book.name || 'N/A'}</small></td>
            <td><small>${book.author || 'N/A'}</small></td>
            <td><small>${book.publisher || 'N/A'}</small></td>
            <td><small><span class="badge bg-secondary">${book.library}</span></small></td>
          </tr>`;
        });

        html += `</tbody>
              </table>
            </div>
          </div>
        </div>`;
      });

      html += `<button class="btn btn-lg btn-success" onclick="mergeDuplicates()">
        <i class="fas fa-code-merge"></i> Merge Selected Records
      </button></div></div>`;

      container.innerHTML = html;
    });
  }

  function toggleBook(checkbox, groupIndex) {
    const checkboxes = document.querySelectorAll(`.book-selector[data-group="${groupIndex}"]`);
    checkboxes.forEach(cb => cb.checked = checkbox.checked);
  }

  function mergeDuplicates() {
    const selected = document.querySelectorAll('.book-selector:checked');
    if (selected.length < 2) {
      alert('Please select at least 2 books to merge');
      return;
    }

    const sourceIds = Array.from(selected).map(cb => cb.dataset.id);
    const canonicalId = sourceIds[0]; // First selected is canonical

    if (!confirm(`Merge ${sourceIds.length} records into one? This cannot be undone.`)) {
      return;
    }

    fetch('<%= admin_merge_duplicates_path %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({
        source_ids: sourceIds,
        canonical_id: canonicalId
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        alert(data.message);
        document.getElementById('resultsContainer').innerHTML = '';
      } else {
        alert('Error: ' + (data.error || 'Unknown error'));
      }
    });
  }

  function selectGroup(index) {
    const checkboxes = document.querySelectorAll(`.book-selector[data-group="${index}"]`);
    checkboxes.forEach(cb => cb.checked = true);
  }
</script>
