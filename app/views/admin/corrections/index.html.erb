<% content_for :page_title do %>
  Corrections & Edits
<% end %>

<div class="row">
  <div class="col-md-12">
    <div class="card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="card-title" style="color: #5F3792; margin: 0;">
            <i class="fas fa-edit"></i> All Book Corrections
          </h5>
          <a href="<%= admin_audit_log_path %>" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-history"></i> View Audit Log
          </a>
        </div>

        <% if @edits.any? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead style="background: #f5f5f5;">
                <tr>
                  <th>Date</th>
                  <th>Editor</th>
                  <th>Book ID</th>
                  <th>Field</th>
                  <th>Old Value</th>
                  <th>New Value</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @edits.each do |edit| %>
                  <tr>
                    <td>
                      <small><%= edit.timestamp.strftime('%b %d, %Y %H:%M') %></small>
                    </td>
                    <td>
                      <small><%= edit.editor %></small>
                    </td>
                    <td>
                      <small style="font-family: monospace;">
                        <%= truncate(edit.source_identifier, length: 20) %>
                      </small>
                    </td>
                    <td>
                      <small>
                        <span class="badge bg-info"><%= edit.field %></span>
                      </small>
                    </td>
                    <td>
                      <small style="color: #999;">
                        <%= truncate(edit.old_value, length: 30) %>
                      </small>
                    </td>
                    <td>
                      <small style="color: #333; font-weight: 500;">
                        <%= truncate(edit.new_value, length: 30) %>
                      </small>
                    </td>
                    <td>
                      <button class="btn btn-sm btn-outline-danger" 
                              onclick="undoEdit('<%= edit.id %>', this)"
                              title="Undo this edit">
                        <i class="fas fa-undo"></i> Undo
                      </button>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <nav class="mt-4">
            <%= paginate @edits %>
          </nav>
        <% else %>
          <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No corrections yet.
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  function undoEdit(editId, button) {
    if (!confirm('Are you sure you want to undo this edit?')) {
      return;
    }

    button.disabled = true;
    button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Undoing...';

    const csrfToken = document.querySelector('meta[name="csrf-token"]');
    if (!csrfToken) {
      alert('Error: CSRF token not found. Please refresh the page.');
      button.disabled = false;
      button.innerHTML = '<i class="fas fa-undo"></i> Undo';
      return;
    }

    fetch('<%= admin_corrections_path %>', {
      method: 'DELETE',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken.content
      },
      body: JSON.stringify({ edit_id: editId })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      if (data.success) {
        button.closest('tr').style.opacity = '0.5';
        button.disabled = false;
        button.innerHTML = '<i class="fas fa-check"></i> Undone';
        setTimeout(() => {
          location.reload();
        }, 1000);
      } else {
        alert('Error undoing edit: ' + (data.error || 'Unknown error'));
        button.disabled = false;
        button.innerHTML = '<i class="fas fa-undo"></i> Undo';
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error: ' + error.message);
      button.disabled = false;
      button.innerHTML = '<i class="fas fa-undo"></i> Undo';
    });
  }
</script>
