<% content_for :page_title do %>
  Audit Log
<% end %>

<div class="row">
  <div class="col-md-12">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title" style="color: #5F3792;">
          <i class="fas fa-history"></i> Complete Activity Log
        </h5>

        <% if @audit_log.any? %>
          <div class="table-responsive">
            <table class="table table-sm table-hover">
              <thead style="background: #f5f5f5;">
                <tr>
                  <th>Timestamp</th>
                  <th>Type</th>
                  <th>Editor</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody>
                <% @audit_log.each do |item| %>
                  <tr>
                    <td style="white-space: nowrap;">
                      <small><%= item.timestamp.strftime('%b %d, %Y %H:%M:%S') %></small>
                    </td>
                    <td>
                      <% if item.correction_type == 'edit' %>
                        <span class="badge bg-info">Book Edit</span>
                      <% elsif item.correction_type == 'merge' %>
                        <span class="badge bg-warning text-dark">Merge</span>
                      <% end %>
                    </td>
                    <td>
                      <small><%= item.editor %></small>
                    </td>
                    <td>
                      <small style="color: #666;">
                        <% if item.correction_type == 'edit' %>
                          Changed <strong><%= item.field %></strong> 
                          from '<code><%= truncate(item.old_value, length: 25) %></code>' 
                          to '<code><%= truncate(item.new_value, length: 25) %></code>'
                          <br>
                          <code style="font-size: 11px; color: #999;"><%= truncate(item.source_identifier, length: 40) %></code>
                        <% elsif item.correction_type == 'merge' %>
                          <% source_ids_len = JSON.parse(item.source_ids || '[]').length %>
                          Merged <%= source_ids_len %> records into 
                          <code><%= truncate(item.canonical_id, length: 30) %></code>
                          <br>
                          <%= truncate(item.description, length: 60) %>
                        <% end %>
                      </small>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <nav class="mt-4">
            <%= paginate @audit_log %>
          </nav>
        <% else %>
          <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No activity recorded yet.
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
