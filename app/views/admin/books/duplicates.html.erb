<% content_for :page_title, 'Duplicate Books' %>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1>Duplicate Books</h1>
      <p class="text-muted mb-0">
        <strong><%= @total_duplicates %></strong> duplicate records across
        <strong><%= @total_groups %></strong> groups
        (grouped by <%= @group_by == 'archive_url' ? 'Archive URL' : 'Book Link' %>)
      </p>
    </div>
    <div>
      <a href="<%= admin_books_path %>" class="btn btn-outline-secondary btn-sm">&larr; All Books</a>
    </div>
  </div>

  <!-- Group By Toggle -->
  <div class="mb-3">
    <div class="btn-group" role="group">
      <a href="<%= admin_duplicates_books_path(library: @library, group_by: 'archive_url') %>"
         class="btn btn-sm <%= @group_by == 'archive_url' ? 'btn-primary' : 'btn-outline-primary' %>">Archive URL</a>
      <a href="<%= admin_duplicates_books_path(library: @library, group_by: 'book_link') %>"
         class="btn btn-sm <%= @group_by == 'book_link' ? 'btn-primary' : 'btn-outline-primary' %>">Book Link</a>
    </div>
  </div>

  <!-- Library Filter -->
  <% if @libraries.any? %>
  <div class="mb-4">
    <div class="btn-group flex-wrap" role="group">
      <a href="<%= admin_duplicates_books_path(group_by: @group_by) %>" class="btn btn-sm <%= @library.blank? ? 'btn-primary' : 'btn-outline-primary' %>">All Libraries</a>
      <% @libraries.each do |lib| %>
        <a href="<%= admin_duplicates_books_path(library: lib, group_by: @group_by) %>" class="btn btn-sm <%= @library == lib ? 'btn-primary' : 'btn-outline-primary' %>"><%= lib %></a>
      <% end %>
    </div>
  </div>
  <% end %>

  <!-- Duplicate Groups -->
  <% @duplicate_groups.each_with_index do |group, idx| %>
    <div class="card mb-4" id="group-<%= idx %>">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <a href="<%= group[:source_url] %>" target="_blank" class="text-truncate d-inline-block" style="max-width:500px;">
            <strong><%= group[:source_url] %></strong>
          </a>
          <span class="badge bg-warning text-dark ms-2"><%= group[:count] %> copies</span>
        </div>
        <button class="btn btn-sm btn-success merge-btn" data-group="<%= idx %>"
          onclick="mergeGroup(<%= idx %>)">Merge & Keep Best</button>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th style="width:40px;"><input type="checkbox" class="select-all" data-group="<%= idx %>" onchange="toggleGroup(<%= idx %>, this.checked)"></th>
              <th>ID</th>
              <th>Name</th>
              <th>Author</th>
              <th>Publisher</th>
              <th>Year</th>
              <th>Library</th>
              <th>Contributions</th>
              <th style="width:100px;">Keep</th>
            </tr>
          </thead>
          <tbody>
            <% group[:books].each_with_index do |book, bidx| %>
              <tr data-book-id="<%= book[:id] %>">
                <td><input type="checkbox" class="dupe-check" data-group="<%= idx %>" value="<%= book[:id] %>"></td>
                <td><%= book[:id] %></td>
                <td><%= book[:name] %></td>
                <td><%= book[:author] || '-' %></td>
                <td><%= book[:publisher] || '-' %></td>
                <td><%= book[:year] || '-' %></td>
                <td><%= book[:library] %></td>
                <td><span class="badge bg-info"><%= book[:contributions_count] %></span></td>
                <td>
                  <button class="btn btn-sm btn-outline-primary keep-btn" data-group="<%= idx %>" data-book-id="<%= book[:id] %>"
                    onclick="setKeeper(<%= idx %>, <%= book[:id] %>)">Keep</button>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if @duplicate_groups.empty? %>
    <div class="text-center py-5 text-muted">
      <i class="fa fa-check-circle" style="font-size:48px;color:#4CAF50;"></i>
      <p class="mt-3">No duplicate books found.</p>
    </div>
  <% end %>

  <!-- Pagination -->
  <% if @total_groups > 30 %>
    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% if @page > 1 %>
          <li class="page-item"><a class="page-link" href="<%= admin_duplicates_books_path(library: @library, group_by: @group_by, page: @page - 1) %>">Previous</a></li>
        <% end %>
        <% total_pages = (@total_groups / 30.0).ceil %>
        <% (1..total_pages).each do |p| %>
          <li class="page-item <%= 'active' if p == @page %>">
            <a class="page-link" href="<%= admin_duplicates_books_path(library: @library, group_by: @group_by, page: p) %>"><%= p %></a>
          </li>
        <% end %>
        <% if @page < total_pages %>
          <li class="page-item"><a class="page-link" href="<%= admin_duplicates_books_path(library: @library, group_by: @group_by, page: @page + 1) %>">Next</a></li>
        <% end %>
      </ul>
    </nav>
  <% end %>
</div>

<script>
var keepers = {};

function toggleGroup(groupIdx, checked) {
  var checks = document.querySelectorAll('.dupe-check[data-group="' + groupIdx + '"]');
  checks.forEach(function(c) { c.checked = checked; });
}

function setKeeper(groupIdx, bookId) {
  keepers[groupIdx] = bookId;
  var rows = document.querySelectorAll('#group-' + groupIdx + ' tr[data-book-id]');
  rows.forEach(function(row) {
    var btn = row.querySelector('.keep-btn');
    var id = parseInt(row.getAttribute('data-book-id'));
    if (id === bookId) {
      btn.className = 'btn btn-sm btn-success keep-btn';
      btn.textContent = 'Keeping';
      row.style.background = '#e8f5e9';
    } else {
      btn.className = 'btn btn-sm btn-outline-primary keep-btn';
      btn.textContent = 'Keep';
      row.style.background = '';
    }
  });
}

function mergeGroup(groupIdx) {
  var keeperId = keepers[groupIdx];
  if (!keeperId) {
    alert('Please click "Keep" on the book you want to keep.');
    return;
  }

  var checks = document.querySelectorAll('.dupe-check[data-group="' + groupIdx + '"]:checked');
  var removeIds = [];
  checks.forEach(function(c) {
    var id = parseInt(c.value);
    if (id !== keeperId) removeIds.push(id);
  });

  if (removeIds.length === 0) {
    alert('Please check the duplicate books to remove.');
    return;
  }

  if (!confirm('Keep book #' + keeperId + ' and remove ' + removeIds.length + ' duplicate(s)?')) return;

  fetch('<%= admin_merge_duplicates_books_path %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= form_authenticity_token %>' },
    body: JSON.stringify({ keeper_id: keeperId, remove_ids: removeIds })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      document.getElementById('group-' + groupIdx).remove();
    } else {
      alert(data.error || 'Merge failed');
    }
  })
  .catch(function() { alert('Error merging books'); });
}
</script>
