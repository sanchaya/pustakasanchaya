<% content_for :page_title, "Edit: #{@book.name}" %>
<div class="container-fluid mt-4">
  <!-- Header -->
  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <h1><%= @book.name %></h1>
      <p class="text-muted">
        ID: <%= @book.id %> &middot;
        Source: <%= @book.source_identifier %>
        <% if @book.year %>&middot; <%= @book.year %><% end %>
      </p>
    </div>
    <div>
      <a href="<%= admin_books_path %>" class="btn btn-outline-secondary btn-sm">&larr; All Books</a>
    </div>
  </div>

  <%= form_for @book, url: admin_update_form_book_path(@book), method: :post, html: { class: 'row' } do |f| %>

  <!-- ======== LEFT COLUMN ======== -->
  <div class="col-md-7">

    <!-- Title & Identity -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Title &amp; Identity</h5></div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-8 mb-3">
            <%= f.label :name, 'Primary Title', class: 'form-label' %>
            <%= f.text_field :name, class: 'form-control kan-ime' %>
          </div>
          <div class="col-md-4 mb-3">
            <%= f.label :language, 'Language', class: 'form-label' %>
            <%= f.text_field :language, class: 'form-control', placeholder: 'e.g. Kannada, English' %>
          </div>
        </div>
        <div class="mb-3">
          <%= f.label :name_kannada, 'Title in Kannada Script', class: 'form-label' %>
          <%= f.text_field :name_kannada, class: 'form-control kan-ime' %>
        </div>
        <div class="mb-3">
          <%= f.label :name_latin, 'Title in Latin Script (Transliteration)', class: 'form-label' %>
          <%= f.text_field :name_latin, class: 'form-control' %>
        </div>
        <div class="mb-3">
          <%= f.label :name_english, 'Title in English', class: 'form-label' %>
          <%= f.text_field :name_english, class: 'form-control' %>
        </div>
      </div>
    </div>

    <!-- Contributors -->
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Contributors</h5>
        <button type="button" class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#addContributorModal">+ Add Person</button>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="contributorsTable">
          <thead class="table-light">
            <tr><th>Name</th><th>Role</th><th>Profile</th><th style="width: 50px;"></th></tr>
          </thead>
          <tbody>
            <% @contributions.each do |c| %>
            <tr data-contribution-id="<%= c.id %>">
              <td><%= c.person.name %></td>
              <td><span class="badge bg-secondary"><%= c.role.humanize %></span></td>
              <td><a href="<%= admin_person_path(c.person) %>" target="_blank" class="btn btn-sm btn-outline-info">View</a></td>
              <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeContributor(<%= c.id %>)">&times;</button></td>
            </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @contributions.empty? %>
      <div class="card-body text-center text-muted py-3">No contributors linked. Add people via "Add Person".</div>
      <% end %>
    </div>

    <!-- Original Authors (flat fields) -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Legacy Author Fields</h5></div>
      <div class="card-body">
        <p class="text-muted small">These flat fields are used by the search system. New contributors should be added above.</p>
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :author, 'Author', class: 'form-label' %>
            <%= f.text_field :author, class: 'form-control kan-ime' %>
          </div>
          <div class="col-md-3 mb-3">
            <%= f.label :author_role, 'Role', class: 'form-label' %>
            <%= f.text_field :author_role, class: 'form-control' %>
          </div>
          <div class="col-md-3 mb-3">
            <%= f.label :author_kannada, 'Kannada', class: 'form-label' %>
            <%= f.text_field :author_kannada, class: 'form-control kan-ime' %>
          </div>
        </div>
        <div class="row">
          <div class="col-md-4 mb-3">
            <%= f.label :author_latin, 'Latin', class: 'form-label' %>
            <%= f.text_field :author_latin, class: 'form-control' %>
          </div>
          <div class="col-md-4 mb-3">
            <%= f.label :author_2, 'Author 2', class: 'form-label' %>
            <%= f.text_field :author_2, class: 'form-control' %>
          </div>
          <div class="col-md-4 mb-3">
            <%= f.label :author_2_role, 'Author 2 Role', class: 'form-label' %>
            <%= f.text_field :author_2_role, class: 'form-control' %>
          </div>
        </div>
        <div class="row">
          <div class="col-md-4 mb-3">
            <%= f.label :author_3, 'Author 3', class: 'form-label' %>
            <%= f.text_field :author_3, class: 'form-control' %>
          </div>
          <div class="col-md-4 mb-3">
            <%= f.label :author_3_role, 'Author 3 Role', class: 'form-label' %>
            <%= f.text_field :author_3_role, class: 'form-control' %>
          </div>
        </div>
      </div>
    </div>

    <!-- Publisher / Printer -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Publisher &amp; Printer</h5></div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :publisher, 'Publisher Name', class: 'form-label' %>
            <%= f.text_field :publisher, class: 'form-control' %>
          </div>
          <div class="col-md-3 mb-3">
            <%= f.label :publisher_kannada, 'Publisher (Kannada)', class: 'form-label' %>
            <%= f.text_field :publisher_kannada, class: 'form-control kan-ime' %>
          </div>
          <div class="col-md-3 mb-3">
            <%= f.label :publisher_latin, 'Publisher (Latin)', class: 'form-label' %>
            <%= f.text_field :publisher_latin, class: 'form-control' %>
          </div>
        </div>
        <div class="mb-3">
          <%= f.label :place_of_publication, 'Place of Publication', class: 'form-label' %>
          <%= f.text_field :place_of_publication, class: 'form-control', placeholder: 'City, State' %>
        </div>
        <hr>
        <div class="mb-3">
          <%= f.label :printer_name, 'Printer Name', class: 'form-label' %>
          <%= f.text_field :printer_name, class: 'form-control' %>
        </div>
        <div class="mb-3">
          <%= f.label :printer_address, 'Printer Address', class: 'form-label' %>
          <%= f.text_area :printer_address, class: 'form-control', rows: 2, placeholder: 'Full address of printing press' %>
        </div>
      </div>
    </div>

    <!-- Edition & Bibliographic Details -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Edition &amp; Bibliographic Details</h5></div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-3 mb-3">
            <%= f.label :year, 'Year of Publication', class: 'form-label' %>
            <%= f.text_field :year, class: 'form-control', placeholder: 'YYYY' %>
          </div>
          <div class="col-md-3 mb-3">
            <%= f.label :edition, 'Edition', class: 'form-label' %>
            <%= f.text_field :edition, class: 'form-control', placeholder: 'e.g. 1st, 2nd' %>
          </div>
          <div class="col-md-3 mb-3">
            <%= f.label :isbn, 'ISBN', class: 'form-label' %>
            <%= f.text_field :isbn, class: 'form-control', placeholder: 'ISBN number' %>
          </div>
          <div class="col-md-3 mb-3">
            <%= f.label :pages, 'Pages', class: 'form-label' %>
            <%= f.number_field :pages, class: 'form-control', placeholder: 'Page count' %>
          </div>
        </div>
        <div class="mb-3">
          <%= f.label :series, 'Series', class: 'form-label' %>
          <%= f.text_field :series, class: 'form-control', placeholder: 'Book series name' %>
        </div>
      </div>
    </div>
  </div>

  <!-- ======== RIGHT COLUMN ======== -->
  <div class="col-md-5">

    <!-- Translation Info -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Translation Details</h5></div>
      <div class="card-body">
        <div class="form-check mb-3">
          <%= f.check_box :is_translation, class: 'form-check-input', onclick: 'toggleTranslationFields(this.checked)' %>
          <%= f.label :is_translation, 'This is a translation', class: 'form-check-label' %>
        </div>
        <div id="translationFields" class="<%= 'd-none' unless @book.is_translation? %>">
          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.label :translation_source_lang, 'Source Language', class: 'form-label' %>
              <%= f.text_field :translation_source_lang, class: 'form-control', placeholder: 'e.g. English, Hindi' %>
            </div>
            <div class="col-md-6 mb-3">
              <%= f.label :translation_dest_lang, 'Destination Language', class: 'form-label' %>
              <%= f.text_field :translation_dest_lang, class: 'form-control', placeholder: 'e.g. Kannada' %>
            </div>
          </div>
          <hr>
          <h6>Original Work</h6>
          <div class="mb-3">
            <%= f.label :original_title, 'Original Title', class: 'form-label' %>
            <%= f.text_field :original_title, class: 'form-control' %>
          </div>
          <div class="mb-3">
            <%= f.label :original_author, 'Original Author', class: 'form-label' %>
            <%= f.text_field :original_author, class: 'form-control' %>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.label :original_publisher, 'Original Publisher', class: 'form-label' %>
              <%= f.text_field :original_publisher, class: 'form-control' %>
            </div>
            <div class="col-md-3 mb-3">
              <%= f.label :original_year, 'Original Year', class: 'form-label' %>
              <%= f.text_field :original_year, class: 'form-control', placeholder: 'YYYY' %>
            </div>
            <div class="col-md-3 mb-3">
              <%= f.label :original_language, 'Original Language', class: 'form-label' %>
              <%= f.text_field :original_language, class: 'form-control' %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Categories -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Categories</h5></div>
      <div class="card-body">
        <%= f.label :categories, 'Categories (pipe-separated)', class: 'form-label' %>
        <%= f.text_field :categories, class: 'form-control', placeholder: 'e.g. Fiction | Kannada Literature | Poetry' %>
        <small class="text-muted">Separate multiple categories with a pipe | or comma</small>
      </div>
    </div>

    <!-- Summary -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Summary / Description</h5></div>
      <div class="card-body">
        <%= f.text_area :summary, class: 'form-control', rows: 5, placeholder: 'Brief summary or description of the book...' %>
      </div>
    </div>

    <!-- Library & Source -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Library &amp; Source</h5></div>
      <div class="card-body">
        <div class="mb-3">
          <%= f.label :library, 'Library', class: 'form-label' %>
          <%= f.text_field :library, class: 'form-control' %>
        </div>
        <div class="mb-3">
          <%= f.label :source, 'Source', class: 'form-label' %>
          <%= f.text_field :source, class: 'form-control' %>
        </div>
        <div class="mb-3">
          <%= f.label :book_link, 'Book Link (URL)', class: 'form-label' %>
          <%= f.url_field :book_link, class: 'form-control' %>
        </div>
        <div class="mb-3">
          <%= f.label :archive_url, 'Archive URL', class: 'form-label' %>
          <%= f.url_field :archive_url, class: 'form-control' %>
        </div>
      </div>
    </div>

    <!-- Thumbnail -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Thumbnail</h5></div>
      <div class="card-body">
        <% if @book.thumbnail.present? %>
          <div class="text-center mb-3">
            <img src="<%= @book.thumbnail %>" alt="Thumbnail" style="max-height: 150px;" class="img-thumbnail">
          </div>
        <% end %>
        <div class="mb-3">
          <%= f.label :thumbnail, 'Thumbnail URL', class: 'form-label' %>
          <%= f.url_field :thumbnail, class: 'form-control' %>
        </div>
        <button type="button" class="btn btn-sm btn-outline-primary" onclick="fetchThumbnail(<%= @book.id %>)">Auto-Fetch Thumbnail</button>
        <button type="button" class="btn btn-sm btn-outline-warning" onclick="resetThumbnailFailed(<%= @book.id %>)">Reset Failed Sources</button>
      </div>
    </div>

    <!-- Correction Log -->
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Edit History</h5></div>
      <div class="card-body" style="max-height: 300px; overflow-y: auto;">
        <% if @corrections.present? %>
          <ul class="list-unstyled mb-0">
          <% @corrections.last(20).each do |c| %>
            <li class="mb-2 small">
              <strong><%= c.field %></strong>:
              "<%= truncate(c.old_value.to_s, length: 40) %>" &rarr; "<%= truncate(c.new_value.to_s, length: 40) %>"
              <br><span class="text-muted">by <%= c.editor_email %> on <%= c.created_at.to_s(:short) %></span>
            </li>
          <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No edit history recorded.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Save footer -->
  <div class="col-12">
    <div class="sticky-bottom bg-white py-3 border-top" style="margin: 0 -12px; padding: 12px !important;">
      <div class="row align-items-center">
        <div class="col-md-8">
          <%= text_field_tag :correction_description, params[:correction_description], class: 'form-control form-control-sm', placeholder: 'Describe what changed (optional, for audit log)' %>
        </div>
        <div class="col-md-4 text-end">
          <%= f.submit 'Save Book', class: 'btn btn-primary px-4' %>
          <a href="<%= admin_edit_form_book_path(@book) %>" class="btn btn-outline-secondary ms-2">Reset</a>
        </div>
      </div>
    </div>
  </div>
  <% end %>
</div>

<!-- Add Contributor Modal -->
<div class="modal fade" id="addContributorModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Link Person to Book</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Search for a Person</label>
          <input type="text" id="contributorSearchInput" class="form-control" placeholder="Type person name..." oninput="searchContributors()">
        </div>
        <div id="contributorSearchResults" class="mb-3"></div>
        <div class="mb-3">
          <label class="form-label">Role</label>
          <select id="newContributorRole" class="form-select">
            <% Person.roles.each do |role| %>
              <option value="<%= role %>"><%= role.humanize %></option>
            <% end %>
          </select>
        </div>
        <div id="addContributorError" class="alert alert-danger d-none"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-success" onclick="submitAddContributor()">Add to Book</button>
      </div>
    </div>
  </div>
</div>

<script>
var selectedPersonId = null;
var bookId = <%= @book.id %>;

function toggleTranslationFields(checked) {
  document.getElementById('translationFields').classList.toggle('d-none', !checked);
}

function searchContributors() {
  var q = document.getElementById('contributorSearchInput').value;
  if (!q || q.trim().length < 2) { document.getElementById('contributorSearchResults').innerHTML = ''; return; }
  fetch('/admin/people/find-similar?q=' + encodeURIComponent(q), {
    headers: { 'X-CSRF-Token': '<%= form_authenticity_token %>' }
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    var results = document.getElementById('contributorSearchResults');
    if (!data.similar || data.similar.length === 0) {
      results.innerHTML = '<small class="text-muted">No people found. <a href="<%= admin_people_path %>" target="_blank">Create a new person</a> first.</small>';
      return;
    }
    var html = '<div class="list-group" style="max-height: 250px; overflow-y: auto;">';
    data.similar.forEach(function(p) {
      html += '<button type="button" class="list-group-item list-group-item-action person-result" data-person-id="' + p.id + '" onclick="selectPerson(' + p.id + ', \'' + p.name.replace(/'/g, "\\'") + '\')">' + p.name + '</button>';
    });
    html += '</div>';
    results.innerHTML = html;
  });
}

function selectPerson(personId, personName) {
  selectedPersonId = personId;
  document.getElementById('contributorSearchInput').value = personName;
  document.getElementById('contributorSearchResults').innerHTML = '';
}

function submitAddContributor() {
  if (!selectedPersonId) {
    document.getElementById('addContributorError').textContent = 'Please select a person';
    document.getElementById('addContributorError').classList.remove('d-none');
    return;
  }
  var role = document.getElementById('newContributorRole').value;
  fetch('/admin/people/' + selectedPersonId + '/contributions/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= form_authenticity_token %>' },
    body: JSON.stringify({ book_id: bookId, role: role })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) { location.reload(); }
    else {
      document.getElementById('addContributorError').textContent = data.error || 'Failed to add';
      document.getElementById('addContributorError').classList.remove('d-none');
    }
  });
}

function removeContributor(contributionId) {
  if (!confirm('Remove this person from the book?')) return;
  fetch('/admin/books/' + bookId + '/remove_contribution', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= form_authenticity_token %>' },
    body: JSON.stringify({ contribution_id: contributionId })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      var row = document.querySelector('tr[data-contribution-id="' + contributionId + '"]');
      if (row) row.remove();
    }
  });
}

function fetchThumbnail(bookId) {
  fetch('/admin/books/' + bookId + '/fetch_thumbnail?force=true', {
    method: 'POST',
    headers: { 'X-CSRF-Token': '<%= form_authenticity_token %>' }
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) location.reload();
    else alert(data.message || 'Failed to fetch thumbnail');
  });
}

function resetThumbnailFailed(bookId) {
  fetch('/admin/books/' + bookId + '/reset_thumbnail_failed', {
    method: 'POST',
    headers: { 'X-CSRF-Token': '<%= form_authenticity_token %>' }
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) { alert('Reset successful. Click Auto-Fetch to retry.'); }
  });
}
</script>
