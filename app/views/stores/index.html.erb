<% content_for :page_title do %>
  ಪುಸ್ತಕ ಮಳಿಗೆಗಳು ಮತ್ತು ಗ್ರಂಥಾಲಯಗಳು
<% end %>

<div class="container">
  <div class="row" style="margin-bottom: 20px;">
    <div class="col-md-12 text-center">
      <h1>ಪುಸ್ತಕ ಮಳಿಗೆಗಳು ಮತ್ತು ಗ್ರಂಥಾಲಯಗಳು</h1>
      <p class="text-muted">ಈ ಆನ್‌ಲೈನ್ ಮಳಿಗೆಗಳು ಮತ್ತು ಡಿಜಿಟಲ್ ಗ್ರಂಥಾಲಯಗಳಲ್ಲಿ ಕನ್ನಡ ಪುಸ್ತಕಗಳನ್ನು ಹುಡುಕಿರಿ</p>
    </div>
  </div>

  <div class="row" style="margin-bottom: 20px;">
    <div class="col-md-12 text-center">
      <button type="button" onclick="toggleSuggestionForm()" style="background: none; border: 1px dashed #5F3792; color: #5F3792; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-size: 14px;">
        + ಹೊಸ ಮೂಲ/ಮಳಿಗೆ/ಗ್ರಂಥಾಲಯ ಸೂಚಿಸಿ
      </button>
    </div>
  </div>

  <div id="suggestion-form" style="display: none; margin-bottom: 20px;">
    <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px; background: #f8f9fa;">
      <form action="mailto:info@sanchaya.org" method="post" enctype="text/plain" onsubmit="return prepareSuggestion(event)">
        <div style="margin-bottom: 12px;">
          <label style="display: block; margin-bottom: 4px; font-weight: bold;">ನಿಮ್ಮ ಹೆಸರು</label>
          <input type="text" name="name" placeholder="ಐಚ್ಛಿಕ" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
        </div>
        <div style="margin-bottom: 12px;">
          <label style="display: block; margin-bottom: 4px; font-weight: bold;">ಪ್ರಕಾರ</label>
          <select name="type" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            <option value="store">ಪುಸ್ತಕ ಮಳಿಗೆ</option>
            <option value="library">ಡಿಜಿಟಲ್ ಗ್ರಂಥಾಲಯ</option>
            <option value="source">ಮೂಲ</option>
            <option value="other">ಇತರೆ</option>
          </select>
        </div>
        <div style="margin-bottom: 12px;">
          <label style="display: block; margin-bottom: 4px; font-weight: bold;">ಹೆಸರು</label>
          <input type="text" name="suggestion[name]" required placeholder="ಉದಾ: ಶ್ರೀನಿಧಿ ಪಬ್ಲಿಕೇಷನ್ಸ್" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
        </div>
        <div style="margin-bottom: 12px;">
          <label style="display: block; margin-bottom: 4px; font-weight: bold;">ಜಾಲತಾಣದ ವಿಳಾಸ (URL)</label>
          <input type="url" name="suggestion[url]" placeholder="https://..." style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
        </div>
        <div style="margin-bottom: 12px;">
          <label style="display: block; margin-bottom: 4px; font-weight: bold;">ಹೆಚ್ಚಿನ ಮಾಹಿತಿ</label>
          <textarea name="suggestion[notes]" rows="3" placeholder="ಐಚ್ಛಿಕ" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;"></textarea>
        </div>
        <button type="submit" style="background: #5F3792; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-size: 14px;">ಸೂಚಿಸಿ</button>
        <button type="button" onclick="toggleSuggestionForm()" style="background: none; border: 1px solid #ccc; color: #666; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-size: 14px; margin-left: 8px;">ರದ್ದುಮಾಡಿ</button>
      </form>
    </div>
  </div>

  <div class="row">
    <% @stores.each do |store| %>
      <div class="col-sm-4">
        <div style="display: flex; align-items: center; border: 1px solid #e0e0e0; border-radius: 8px; padding: 15px; margin-bottom: 15px; background: #fff;">
          <% if store.logo.present? %>
            <div style="flex-shrink: 0; margin-right: 15px;">
              <img src="<%= store.logo %>" alt="<%= store.name %>" style="width: 64px; height: 64px; object-fit: contain;">
            </div>
          <% end %>
          <div style="flex: 1;">
            <div style="font-size: 16px; font-weight: bold; margin-bottom: 5px;"><%= store.name %></div>
            <% if store.url.present? %>
              <a href="<%= store.url %>" target="_blank" style="font-size: 13px;">ಭೇಟಿ ಕೊಡಿ</a>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
function toggleSuggestionForm() {
  var form = document.getElementById('suggestion-form');
  form.style.display = form.style.display === 'none' ? 'block' : 'none';
}

function prepareSuggestion(event) {
  var form = event.target;
  var name = form.querySelector('input[name="name"]').value;
  var type = form.querySelector('select[name="type"]').value;
  var sname = form.querySelector('input[name="suggestion[name]"]').value;
  var url = form.querySelector('input[name="suggestion[url]"]').value;
  var notes = form.querySelector('textarea[name="suggestion[notes]"]').value;

  var body = 'ಹೊಸ ಸೂಚನೆ\n';
  body += '==========\n\n';
  if (name) body += 'ಸೂಚಿಸಿದವರು: ' + name + '\n';
  body += 'ಪ್ರಕಾರ: ' + type + '\n';
  body += 'ಹೆಸರು: ' + sname + '\n';
  if (url) body += 'URL: ' + url + '\n';
  if (notes) body += 'ಹೆಚ್ಚಿನ ಮಾಹಿತಿ: ' + notes + '\n';

  form.querySelector('input[name="name"]').name = 'body';
  form.querySelector('select[name="type"]').remove();
  form.querySelector('input[name="suggestion[name]"]').remove();
  form.querySelector('input[name="suggestion[url]"]').remove();
  form.querySelector('textarea[name="suggestion[notes]"]').remove();

  form.querySelector('input[name="body"]').value = body;
  form.action = 'mailto:info@sanchaya.org?subject=' + encodeURIComponent('ಹೊಸ ಮೂಲ/ಮಳಿಗೆ ಸೂಚನೆ: ' + sname);
  return true;
}
</script>
