<% shown_urls = [] %>
<% if book_source.book_stores.loaded? || book_source.book_stores.any? %>
  <% book_source.book_stores.each do |bs| %>
    <% next unless bs.store %>
    <% url = bs.store_url.presence || book_source.book_link.presence || book_source.archive_url %>
    <% next if url.blank? || shown_urls.include?(url) || url.include?('oudl.osmania.ac.in') || url.include?('dli.gov.in') %>
    <% shown_urls << url %>
    <span class="source-item" style="display: inline-block; margin-right: 8px;">
      <% if bs.store.logo.present? %>
        <a href="<%= url %>" target="_blank" title="<%= bs.store.name %>">
          <img src="<%= bs.store.logo %>" alt="<%= bs.store.name %>" style="width: 24px; height: 24px; object-fit: contain; vertical-align: middle;">
        </a>
      <% else %>
        <a href="<%= url %>" target="_blank" title="<%= bs.store.name %>" class="source-link" style="font-size: 11px;"><%= bs.store.name %></a>
      <% end %>
    </span>
  <% end %>
<% end %>
<%# Fallback for books without book_stores (legacy library/book_link fields) %>
<% unless shown_urls.any? %>
  <% library_names = (book_source['library'] || '').split(',').map(&:strip).reject(&:blank?) %>
  <% if library_names.any? %>
    <% library_names.each do |lib_name| %>
      <% url = book_source.book_link.presence || book_source.archive_url %>
      <% next if url.blank? || shown_urls.include?(url) || url.include?('oudl.osmania.ac.in') || url.include?('dli.gov.in') %>
      <% shown_urls << url %>
      <% logo = local_assigns[:store_logos] ? store_logos[lib_name] : nil %>
      <span class="source-item" style="display: inline-block; margin-right: 8px;">
        <% if logo.present? %>
          <a href="<%= url %>" target="_blank" title="<%= lib_name %>">
            <img src="<%= logo %>" alt="<%= lib_name %>" style="width: 24px; height: 24px; object-fit: contain; vertical-align: middle;">
          </a>
        <% elsif url.include?('archive.org') %>
          <a href="<%= url %>" target="_blank" title="<%= lib_name || 'Internet Archive' %>">
            <%= image_tag('internet-archive-logo.png', style: 'width: 24px; height: 24px; vertical-align: middle;') %>
          </a>
        <% else %>
          <a href="<%= url %>" target="_blank" title="<%= lib_name %>" class="source-link" style="font-size: 11px;"><%= lib_name %></a>
        <% end %>
      </span>
    <% end %>
  <% else %>
    <% url = book_source.book_link.presence || book_source.archive_url %>
    <% if url.present? %>
      <% lib_name = book_source['library'] %>
      <% logo = local_assigns[:store_logos] ? store_logos[lib_name] : nil %>
      <span class="source-item" style="display: inline-block; margin-right: 8px;">
        <% if logo.present? %>
          <a href="<%= url %>" target="_blank" title="<%= lib_name %>">
            <img src="<%= logo %>" alt="<%= lib_name %>" style="width: 24px; height: 24px; object-fit: contain; vertical-align: middle;">
          </a>
        <% elsif url.include?('archive.org') %>
          <a href="<%= url %>" target="_blank" title="<%= lib_name || 'Internet Archive' %>">
            <%= image_tag('internet-archive-logo.png', style: 'width: 24px; height: 24px; vertical-align: middle;') %>
          </a>
        <% else %>
          <a href="<%= url %>" target="_blank" title="<%= lib_name %>" class="source-link" style="font-size: 11px;"><%= lib_name %></a>
        <% end %>
      </span>
    <% end %>
  <% end %>
<% end %>
