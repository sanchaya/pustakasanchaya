<div class="main-search">
  <div class="intoduction-text">
    <p align="center">
      ಅಂತರಜಾಲದಲ್ಲಿರುವ ಡಿಜಿಟಲ್ ಲೈಬ್ರರಿಗಳಲ್ಲಿನ ಕನ್ನಡ ಪುಸ್ತಕಗಳನ್ನು ಹುಡುಕುವುದನ್ನು ಸುಲಭವಾಗಿಸುವುದು ಪುಸ್ತಕ ಸಂಚಯದ ಮುಖ್ಯ ಗುರಿ.

    </p>
  </div>
  <hr />
  <div class="form-group main-search-field">
    <%= form_tag root_path, method: :get, class: 'search-form' do %>
    <div class="search-input-wrap">
      <%= search_field_tag "search" ,params[:search], autofocus: params[:search] ? false : true , class: 'form-control kan-ime', placeholder: "#{t(:huduku)}" %>
      <%= submit_tag t(:huduku), class: 'btn btn-primary search-btn' %>
    </div>
    <div style="position:absolute;left:-9999px" aria-hidden="true">
      <input type="text" name="website" tabindex="-1" autocomplete="off">
    </div>
    <% end %>
    <script>
      $(function() {
        $('.search-form .kan-ime').on('keydown', function(e) {
          if (e.which === 13) {
            e.preventDefault();
            e.stopImmediatePropagation();
            $(this).closest('form').submit();
          }
        });
      });
    </script>
    <p class="search-bottom-text">         ಪುಸ್ತಕ ಸಂಚಯಕ್ಕೆ ಅವಶ್ಯವಿರುವ ಮಾನವ ಸಂಪನ್ಮೂಲವನ್ನು <a href="https://samooha.sanchaya.net" target="_blank"> ಸಮೂಹ ಸಂಚಯದ </a> ಕ್ರೌಡ್‌ಸೋರ್ಸಿಂಗ್ ಮೂಲಕ ಪಡೆದುಕೊಳ್ಳಲಾಗಿದೆ. ನಮ್ಮ ಯೋಜನೆಗಳಲ್ಲಿ ಭಾಗವಹಿಸಲು ಇಚ್ಛಿಸುವವರು ‍‍ಸಂಚಯ ಸಂಪರ್ಕಿಸಬಹುದು.
    </p>
  </div>
  <hr />
</div>


<% if params && params[:search] && !params[:search].blank? %>
<div class="word-lists">
  <%= render 'book_lists' %>
</div>
<% else %>
<%= render 'stats' %>
<%= render 'year_chart' %>
<% end %>
