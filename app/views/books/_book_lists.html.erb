<table class="table table-striped" id="book-results">
  <thead>
    <tr>
      <th></th>
      <th>  <%= t :book %> </th>
      <th>  <%= t :author %> </th>
      <th>  <%= t :publisher %> </th>
      <th>  <%= t :library %> </th>
      <th>  <%= t :year %> </th>
      <th>  <%= t :book_link %> </th>
    </tr>
  </thead>
  <tbody>
    <%= render partial: 'books/book_row', collection: @books, as: :book_row %>
  </tbody>
</table>
<div id="load-more-area">
  <%= render 'books/load_more_button', load_more_books: @books %>
</div>